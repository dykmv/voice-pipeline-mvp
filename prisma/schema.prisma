generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Lead {
  id            String   @id @default(cuid())
  userId        String   @default("default-user") // Ready for auth later
  name          String
  phone         String   @default("")
  email         String   @default("")
  source        String   @default("")     // Bazaraki, Facebook, WhatsApp, Referral, Other
  budget        String   @default("")
  propertyType  String   @default("")     // Apartment, House, Villa, Commercial, Land
  location      String   @default("")
  status        String   @default("new")  // new, contacted, viewing, deal, won, lost
  followUpDate  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  notes Note[]

  @@index([userId])
  @@index([status])
  @@index([followUpDate])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  text      String
  type      String   @default("note")  // note, status_change, voice
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
}
