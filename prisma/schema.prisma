generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id            String   @id @default(cuid())
  userId        String   @default("default-user")
  name          String
  phone         String   @default("")
  email         String   @default("")
  source        String   @default("")
  budget        String   @default("")
  propertyType  String   @default("")
  location      String   @default("")
  status          String   @default("new")
  followUpDate    DateTime?
  transactionType String   @default("")      // sale|rent|auction
  leadRole        String   @default("")      // buyer|tenant|seller|landlord
  nextAction      String   @default("")      // what to do at follow-up
  viewingDate     DateTime?
  refNumber       String   @default("")      // property reference
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  notes Note[]

  @@index([userId])
  @@index([status])
  @@index([followUpDate])
  @@index([viewingDate])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  text      String
  type      String   @default("note")
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
}
