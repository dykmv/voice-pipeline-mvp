generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String   @default("")
  passwordHash String
  createdAt    DateTime @default(now())

  sessions Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
}

model Lead {
  id              String    @id @default(cuid())
  userId          String
  name            String
  phone           String    @default("")
  email           String    @default("")
  source          String    @default("")
  budget          String    @default("")
  propertyType    String    @default("")
  location        String    @default("")
  status          String    @default("new")
  followUpDate    DateTime?
  transactionType String    @default("")
  leadRole        String    @default("")
  nextAction      String    @default("")
  viewingDate     DateTime?
  refNumber       String    @default("")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  notes Note[]

  @@index([userId])
  @@index([status])
  @@index([followUpDate])
  @@index([viewingDate])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  text      String
  type      String   @default("note")
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
}
